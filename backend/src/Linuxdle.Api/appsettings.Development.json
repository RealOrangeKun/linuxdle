{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "Database": "Host=localhost;Database=linuxdle;Username=linuxdle;Password=linuxdle",
    "Redis": "localhost:6379"
  },
  "AccessTokenOptions": {
    "ExpirationMinutes": 60
  },
  "RefreshTokenOptions": {
    "Secure": false,
    "SameSite": "Lax"
  },
  "RegisterUserRateLimitOptions": {
    "PermitLimit": 20,
    "WindowInSeconds": 3600
  },
  "GlobalRateLimitOptions": {
    "PermitLimit": 50,
    "WindowInSeconds": 60,
    "QueueLimit": 0,
    "AutoReplenishment": true
  },
  "DailyPuzzleOptions": {
    "CronSchedule": "0 0 3 ? * SUN",
    "DaysToSchedule": 30
  },
  "CleanUsersJobOptions": {
    "CronSchedule": "0 0 3 ? * SUN"
  },
  "PrewarmDailyDistroJobOptions": {
    "CronSchedule": "0 2 0 ? * *"
  },
  "PrewarmDailyDesktopEnvironmentJobOptions": {
    "CronSchedule": "0 2 0 ? * *"
  },
  "DistroImageOptions": {
    "InitialQualityPercentage": 0.03,
    "MaxRetries": 12,
    "OutputSize": 300
  },
  "OpenTelemetry": {
    "LokiEndpoint": "http://loki:3100/otlp/v1/logs"
  },
  "HybridCache": {
    "MaximumPayloadBytes": 5242880,
    "MaximumKeyLength": 1024
  }
}