# ── Database ────────────────────────────────────────────
DB_PASSWORD=your_db_password

# ── Redis ────────────────────────────────────────────────
REDIS_PASSWORD=your_redis_password

# ── Cloudflare ───────────────────────────────────────────
CF_TUNNEL_TOKEN=your_cloudflare_tunnel_token
CF_AUTH_EMAIL=your_cloudflare_email
CF_API_TOKEN=your_cloudflare_api_token
CF_ZONE_ID=your_zone_id
CF_RULE_ID=your_rule_id
CF_RULESET_ID=your_ruleset_id

# ── Admin Console ────────────────────────────────────────
ADMIN_CONSOLE_USERNAME=admin
ADMIN_CONSOLE_PASSWORD=your_admin_password
ADMIN_CONSOLE_SECRET_KEY=your_secret_key

# ── Grafana ──────────────────────────────────────────────
GRAFANA_PASSWORD=your_grafana_password
