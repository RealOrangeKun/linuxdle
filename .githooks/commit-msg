#!/usr/bin/env sh
set -eu

if [ "$#" -lt 1 ]; then
  echo "[commit-msg] Missing commit message file argument." >&2
  exit 1
fi

if [ ! -x "./node_modules/.bin/commitlint" ]; then
  echo "[commit-msg] commitlint is not installed." >&2
  echo "[commit-msg] Run: npm install" >&2
  exit 1
fi

./node_modules/.bin/commitlint --edit "$1"